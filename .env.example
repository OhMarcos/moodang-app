# ===================================
# MOODANG.APP 환경변수 설정 가이드
# ===================================
# 이 파일을 .env.local로 복사한 후 값을 채워주세요:
#   cp .env.example .env.local

# --- AI APIs ---
GOOGLE_AI_API_KEY=              # Google AI Studio → Gemini API key (관상 분석용)
ANTHROPIC_API_KEY=              # Anthropic Console → API key (사주 분석용)

# --- Stripe 결제 ---
STRIPE_SECRET_KEY=              # Stripe Dashboard → Developers → API keys → Secret key
STRIPE_WEBHOOK_SECRET=          # Stripe CLI: stripe listen --forward-to localhost:3000/api/payment/webhook
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=  # Stripe Dashboard → Publishable key

# --- App ---
NEXT_PUBLIC_BASE_URL=http://localhost:3000   # 프로덕션: https://moodang.app

# --- Optional: 카카오 공유 ---
# NEXT_PUBLIC_KAKAO_APP_KEY=    # Kakao Developers → 내 애플리케이션 → JavaScript 키
